{
  "productName": "AI Agents Leader",
  "version": "0.1.0",
  "identifier": "com.ai-agents-leader.overlay",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1666",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Agents Leader",
        "width": 340,
        "minWidth": 340,
        "height": 128,
        "minHeight": 128,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": true,
        "center": false,
        "x": 100,
        "y": 100
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {},
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
